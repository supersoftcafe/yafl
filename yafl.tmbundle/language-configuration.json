{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["(", ")"],
        ["[", "]"],
        ["<", ">"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"" },
        { "open": "`", "close": "`" }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["\"", "\""],
        ["`", "`"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(fun|class|interface|let|match)\\b.*[^#]*$"
    }
}
