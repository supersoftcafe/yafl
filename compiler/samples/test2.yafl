namespace Test

import System
import System::IO

class Container(a: String, b: String, c: String)

fun testIO(io: IO): (io: IO, v: Container|IOError)
  ret io.read(10) ?> (io: IO, a: String) =>
      io.read(12) ?> (io: IO, b: String) =>
      io.read(16) ?> (io: IO, c: String) =>
      (io=io, v=Container(a, b, c))

fun main(): System::Int
  let (io, value) = testIO(stdin())
  io.close()
  System::print("Hello\n")
  System::print("Hi there\n")
  System::print("Whato\n")
  ret 1 + 3

