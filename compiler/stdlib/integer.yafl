# Bitwise instances — one per integer type. `&`/`|`/`^` are operators;
# `andNot(a, b)` is `a & ~b`. Float and String implement no Bitwise instance.

let [trait] _bits_int: _BitwiseInt = _BitwiseInt()
typealias [where] _WhereBitwiseInt : Bitwise<System::Int>
class _BitwiseInt() : Bitwise<System::Int>
  fun `~`(value: System::Int): System::Int
    ret __builtin_op__<bigint>("integer_inv", value)
  fun `&`(left: System::Int, right: System::Int): System::Int
    ret __builtin_op__<bigint>("integer_and", left, right)
  fun `|`(left: System::Int, right: System::Int): System::Int
    ret __builtin_op__<bigint>("integer_or", left, right)
  fun `^`(left: System::Int, right: System::Int): System::Int
    ret __builtin_op__<bigint>("integer_xor", left, right)
  fun andNot(left: System::Int, right: System::Int): System::Int
    ret __builtin_op__<bigint>("integer_andnot", left, right)

let [trait] _bits_int8: _BitwiseInt8 = _BitwiseInt8()
typealias [where] _WhereBitwiseInt8 : Bitwise<System::Int8>
class _BitwiseInt8() : Bitwise<System::Int8>
  fun `~`(value: System::Int8): System::Int8
    ret __builtin_op__<int8>("int8_inv", value)
  fun `&`(left: System::Int8, right: System::Int8): System::Int8
