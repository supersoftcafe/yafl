# Shift instances — one per integer type. `<<` multiplies by 2^n; `>>` is an
# arithmetic (floor) shift. Float and String implement no Shift instance.

let [trait] _shift_int: _ShiftInt = _ShiftInt()
typealias [where] _WhereShiftInt : Shift<System::Int>
class _ShiftInt() : Shift<System::Int>
  fun `<<`(left: System::Int, right: System::Int): System::Int
    ret __builtin_op__<bigint>("integer_shl", left, right)
  fun `>>`(left: System::Int, right: System::Int): System::Int
    ret __builtin_op__<bigint>("integer_shr", left, right)

let [trait] _shift_int8: _ShiftInt8 = _ShiftInt8()
typealias [where] _WhereShiftInt8 : Shift<System::Int8>
class _ShiftInt8() : Shift<System::Int8>
  fun `<<`(left: System::Int8, right: System::Int8): System::Int8
    ret __builtin_op__<int8>("int8_shl", left, right)
  fun `>>`(left: System::Int8, right: System::Int8): System::Int8
    ret __builtin_op__<int8>("int8_shr", left, right)

let [trait] _shift_int16: _ShiftInt16 = _ShiftInt16()
typealias [where] _WhereShiftInt16 : Shift<System::Int16>
class _ShiftInt16() : Shift<System::Int16>
  fun `<<`(left: System::Int16, right: System::Int16): System::Int16
    ret __builtin_op__<int16>("int16_shl", left, right)
  fun `>>`(left: System::Int16, right: System::Int16): System::Int16
    ret __builtin_op__<int16>("int16_shr", left, right)

let [trait] _shift_int32: _ShiftInt32 = _ShiftInt32()
typealias [where] _WhereShiftInt32 : Shift<System::Int32>
class _ShiftInt32() : Shift<System::Int32>
  fun `<<`(left: System::Int32, right: System::Int32): System::Int32
    ret __builtin_op__<int32>("int32_shl", left, right)
  fun `>>`(left: System::Int32, right: System::Int32): System::Int32
    ret __builtin_op__<int32>("int32_shr", left, right)

